		{
			"name": "1. STATELESS",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"123\"\n}"
						},
						"url": {
							"raw": "http://localhost:5001/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["login"]
						}
					}
				},
				{
					"name": "Get Profile (with token)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer token_admin_abc123"
							}
						],
						"url": {
							"raw": "http://localhost:5001/profile",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["profile"]
						}
					}
				},
				{
					"name": "Get Data (with token)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer token_admin_abc123"
							}
