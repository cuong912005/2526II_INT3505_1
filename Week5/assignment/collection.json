{
	"info": {
		"_postman_id": "book-management-api",
		"name": "Book Management API",
		"description": "REST API for book management with 3 pagination methods",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000"
		}
	],
	"item": [
		{
			"name": "Get All Books",
			"item": [
				{
					"name": "Get All - Page Based",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books?paginationType=page-based&page=1&pageSize=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books"],
							"query": [
								{"key": "paginationType", "value": "page-based"},
								{"key": "page", "value": "1"},
								{"key": "pageSize", "value": "10"}
							]
						}
					}
				},
				{
					"name": "Get All - Limit Offset",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books?paginationType=limit-offset&limit=10&offset=0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books"],
							"query": [
								{"key": "paginationType", "value": "limit-offset"},
								{"key": "limit", "value": "10"},
								{"key": "offset", "value": "0"}
							]
						}
					}
				},
				{
					"name": "Get All - Cursor Based",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books?paginationType=cursor-based&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books"],
							"query": [
								{"key": "paginationType", "value": "cursor-based"},
								{"key": "limit", "value": "10"}
							]
						}
					}
				},
				{
					"name": "Get All - Cursor Based (with cursor)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books?paginationType=cursor-based&cursor=5&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books"],
							"query": [
								{"key": "paginationType", "value": "cursor-based"},
								{"key": "cursor", "value": "5"},
								{"key": "limit", "value": "10"}
							]
						}
					}
				}
			]
		},
		{
			"name": "Get Book by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", "1"]
				}
			}
		},
		{
			"name": "Create Book",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Clean Code\",\n    \"author\": \"Robert C. Martin\",\n    \"published_year\": 2008,\n    \"genre\": \"Programming\",\n    \"price\": 45.99\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/books",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books"]
				}
			}
		},
		{
			"name": "Update Book",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Clean Code (Updated)\",\n    \"author\": \"Robert C. Martin\",\n    \"published_year\": 2008,\n    \"genre\": \"Programming\",\n    \"price\": 49.99\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/books/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", "1"]
				}
			}
		},
		{
			"name": "Delete Book",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/books/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "books", "1"]
				}
			}
		}
	]
}
