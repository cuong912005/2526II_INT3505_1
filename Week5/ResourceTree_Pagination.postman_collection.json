    {
      "name": "📋 Orders (Cursor-based Pagination)",
      "description": "Order management endpoints using cursor-based pagination strategy",
      "item": [
        {
          "name": "List Orders - First Batch",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/orders?limit=5",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Get first batch of orders with cursor pagination (no cursor = start from beginning)"
          },
          "response": []
        },
        {
          "name": "List Orders - Second Batch",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/orders?cursor=next_5&limit=5",
              "protocol": "http",
              "host": [
