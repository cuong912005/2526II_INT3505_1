  },
  "item": [
    {
      "name": "👥 Users (Offset/Limit Pagination)",
      "description": "User management endpoints using offset/limit pagination strategy",
      "item": [
        {
          "name": "List Users - First Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/users?offset=0&limit=5",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Get first 5 users using offset/limit pagination (skip 0 items, take 5)"
          },
          "response": []
        },
        {
          "name": "List Users - Second Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/users?offset=5&limit=5",
