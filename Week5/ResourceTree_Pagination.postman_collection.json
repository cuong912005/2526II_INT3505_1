                {
                  "key": "offset",
                  "value": "5"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Get next 5 users (skip 5, take 5)"
          },
          "response": []
        },
        {
          "name": "List Users - Third Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/users?offset=10&limit=5",
